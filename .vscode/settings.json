{
  "editor.formatOnSave": true,
  // *******************************
  // 以下设定仅适用于 User Settings
  // *******************************
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": true,
    "scminput": true,
    "yaml": true,
    "html": true,
    "powershell": true,
    "javascript": true,
    "aspnetcorerazor": true
  },
  "chat.editing.confirmEditRequestRemoval": true,
  "chat.editing.confirmEditRequestRetry": true,
  "telemetry.telemetryLevel": "off",

  // ***************************************************
  // 以下设定适用于 User Settings 或 Workspace Settings
  // ***************************************************
  "window.commandCenter": true,
  "chat.commandCenter.enabled": true,

  // 目前 gpt-41-copilot 已经是预设值，但明确设定可确保一致性
  "github.copilot.selectedCompletionModel": "gpt-41-copilot",
  "github.copilot.editor.enableCodeActions": true,
  "github.copilot.renameSuggestions.triggerAutomatically": true,
  "workbench.commandPalette.experimental.askChatLocation": "chatView",
  "search.searchView.semanticSearchBehavior": "runOnEmpty",
  "github.copilot.nextEditSuggestions.enabled": true,
  "editor.inlineSuggest.edits.showCollapsed": true,

  // GitHub Copilot Chat
  "github.copilot.chat.localeOverride": "zh-CN",
  "github.copilot.chat.useProjectTemplates": true,
  "github.copilot.chat.scopeSelection": true,
  "chat.detectParticipant.enabled": false,
  "chat.promptFiles": true,
  "github.copilot.chat.languageContext.typescript.enabled": true,
  "github.copilot.chat.agent.thinkingTool": true,
  // GitHub Copilot Chat - 内嵌聊天 (Inline Chat)
  "github.copilot.chat.editor.temporalContext.enabled": true,
  "inlineChat.holdToSpeech": true,
  "inlineChat.finishOnType": false,
  // GitHub Copilot Chat - 侦错相关设定
  "github.copilot.chat.startDebugging.enabled": true,
  "github.copilot.chat.reviewSelection.enabled": true,
  "github.copilot.chat.copilotDebugCommand.enabled": true,
  "github.copilot.chat.edits.temporalContext.enabled": false,
  // GitHub Copilot Chat - 测试相关设定
  "github.copilot.chat.setupTests.enabled": true,
  "github.copilot.chat.generateTests.codeLens": true,
  "github.copilot.chat.testGeneration.instructions": [
    {
      "file": ".copilot-test-instructions.md"
    },
    {
      "text": "Always try uniting related tests in a suite."
    }
  ],
  // GitHub Copilot Chat - 自订提示
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,
  "github.copilot.chat.codeGeneration.instructions": [
    {
      "text": "When outputing any text, use the following term mappings: create = 创建, object = 对象, queue = 队列, stack = 栈, information = 信息, invocation = 调用, code = 代码, running = 执行, library = 函数库, schematics = 原理图, building = 构建, Setting up = 设定, package = 打包, video = 影片, for loop = for 循环, class = 类, Concurrency = 并发处理, Transaction = 事务, Transactional = 事务性的, Code Snippet = 片段, Code Generation = 代码生成器, Any Class = 任意类, Scalability = 延展性, Dependency Package = 依赖包, Dependency Injection = 依赖注入, Reserved Keywords = 保留关键字, Metadata =  Metadata, Clone = 克隆, Memory = 内存, Built-in = 内建, Global = 全局, Compatibility = 兼容性, Function = 函数, Refresh = 刷新, document = 文件, example = 范例, demo = 展示, quality = 质量, tutorial = 指南, recipes = 专题, byte = 位元组, bit = 位元"
      // "text": "When outputing any text, use the following term mappings: create = , object = 物件, queue = 伫列, stack = 堆叠, information = 资讯, invocation = 呼叫, code = 程式码, running = 执行, library = 函式库, schematics = 原理图, building = 建构, Setting up = 设定, package = 套件, video = 影片, for loop = for 回圈, class = 类别, Concurrency = 平行处理, Transaction = 交易, Transactional = 交易式, Code Snippet = 程式码片段, Code Generation = 程式码产生器, Any Class = 任意类别, Scalability = 延展性, Dependency Package = 相依套件, Dependency Injection = 相依性注入, Reserved Keywords = 保留字, Metadata =  Metadata, Clone = 复制, Memory = 记忆体, Built-in = 内建, Global = 全域, Compatibility = 相容性, Function = 函式, Refresh = 重新整理, document = 文件, example = 范例, demo = 展示, quality = 品质, tutorial = 指南, recipes = 秘诀, byte = 位元组, bit = 位元"
    },
    {
      "text": "Always response in #zh-cn."
    },
    {
      "file": ".copilot-instructions.md"
    }
  ],
  "github.copilot.chat.reviewSelection.instructions": [
    {
      "text": "Always response in #zh-tw."
    },
    {
      "file": ".copilot-review-instructions.md"
    }
  ],
  // GitHub Copilot Chat - 自订 Git Commit 讯息提示
  "github.copilot.chat.commitMessageGeneration.instructions": [
    // {
    //     "text": "# Use Conventional Commits 1.0.0 for commit messages."
    // },
    // {
    //     "text": "请一律使用正体中文来撰写记录"
    // },
    {
      "file": ".copilot-commit-message-instructions.md"
    }
  ],
  // GitHub Copilot Chat - 自订 Pull Request 描述提示
  "github.copilot.chat.pullRequestDescriptionGeneration.instructions": [
    // {
    //     "text": "请一律使用正体中文来撰写记录"
    // },
    // {
    //     "file": ".copilot-pull-request-description-instructions.md"
    // }
  ],
  // GitHub Copilot Chat Edit
  "github.copilot.chat.edits.suggestRelatedFilesForTests": true,
  "github.copilot.chat.edits.suggestRelatedFilesFromGitHistory": true,

  // GitHub Copilot Chat - Agent Mode
  "chat.agent.enabled": true,
  "chat.agent.maxRequests": 100,
  "github.copilot.chat.agent.runTasks": true,
  "github.copilot.chat.codesearch.enabled": true,
  "github.copilot.chat.newWorkspaceCreation.enabled": true,
  // Agent Mode 建议调高预设 Terminal 的卷轴行数
  "terminal.integrated.scrollback": 50000,
  "chat.mcp.discovery.enabled": {
    "claude-desktop": false,
    "windsurf": false,
    "cursor-global": false,
    "cursor-workspace": false
  },
  "mcp": {
    "servers": {}
  },

  // Accessibility
  "accessibility.voice.speechLanguage": "zh-CN",
  "accessibility.voice.autoSynthesize": "off",
  // accessibility.voice.keywordActivation 预设为 off，习惯用语音输入可以改为 chatInContext
  // "accessibility.voice.keywordActivation": "chatInContext",
  "accessibility.voice.speechTimeout": 10000,
  "accessibility.voice.ignoreCodeBlocks": true,

  // Live Preview
  "livePreview.autoRefreshPreview": "On Changes to Saved Files",
  "chat.mcp.access": "all"
}
